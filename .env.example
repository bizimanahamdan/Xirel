# Copy this file to .env and adjust as needed. All values below are optional —
# the app runs fully offline with sensible local defaults if you skip this file.

# Secret used to sign login session cookies. Set this to a long random string
# for anything beyond local testing.
JWT_SECRET=change-me-to-a-long-random-string

# If set, only this exact email can ever become admin (recommended for any
# public/deployed instance, so a stranger can't register first and grab the
# admin account). Leave unset for local use, where the first registered
# account becomes admin automatically.
# ADMIN_EMAIL=you@example.com

# Port the server listens on (default 3000; auto-picks the next free port if busy).
PORT=3000

# Where the local SQLite database file lives (default ./data/store.db).
# DATABASE_FILE=./data/store.db

# Where uploaded product images are stored (default ./data/uploads).
# UPLOADS_DIR=./data/uploads
